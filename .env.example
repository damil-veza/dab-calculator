# Local development: use Neon free tier (recommended) or any PostgreSQL database.
# Get connection strings from https://neon.tech

# Pooled connection (used by the app at runtime on Vercel)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Direct connection (used by Prisma migrations during build)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
